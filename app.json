{
  "expo": {
    "name": "Ambit",
    "slug": "Ambit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ambit",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.winstongu.ambit",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.winstongu.ambit",
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Ambit uses your photos so you can set a profile picture and add work to your portfolio.",
          "cameraPermission": "Ambit uses your camera so you can take a profile picture or capture work for your portfolio."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Ambit uses your calendar to add scheduled meetings."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D4B490",
          "androidMode": "default",
          "androidCollapsedTitle": "New messages on Ambit"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89a80a82-70a2-49e6-a6cf-9f514e302a6e"
      }
    }
  }
}
