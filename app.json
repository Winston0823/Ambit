{
  "expo": {
    "name": "Ambit",
    "slug": "Ambit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ambit",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0C0022"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.winstongu.ambit",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Ambit uses your camera to take a profile photo.",
        "NSPhotoLibraryUsageDescription": "Ambit needs photo access to set your profile picture, project covers, portfolio images, and to attach photos in chat.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.winstongu.ambit"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Ambit needs photo access to set your profile picture, project covers, portfolio images, and to attach photos in chat.",
          "cameraPermission": "Ambit uses your camera to take a profile photo."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Ambit uses your calendar to add scheduled meetings."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2D005E",
          "androidMode": "default",
          "androidCollapsedTitle": "New messages on Ambit"
        }
      ]
    ]
  }
}
